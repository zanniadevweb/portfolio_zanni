{"remainingRequest":"C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\src\\components\\Presentation.vue?vue&type=script&lang=js&","dependencies":[{"path":"C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\src\\components\\Presentation.vue","mtime":1625523282119},{"path":"C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\babel-loader\\lib\\index.js","mtime":315532800000},{"path":"C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\vue-loader\\lib\\index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Presentation.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA6CA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Presentation.vue","sourceRoot":"src/components","sourcesContent":["<template>\n  <v-container id='Presentation'>\n  <v-card class=\"mx-auto\">\n    <v-img src=\"../../public/images/banner.jpg\" tile width=\"100%\"></v-img>\n    <v-card flat tile class=\"mx-auto\" :width=\"largueurElementsDesktop\">\n    <br><br>\n      <v-row class=\"text-center\">\n        <v-col\n          class=\"mb-5\"\n          cols=\"12\"\n        >\n        <v-card-text style=\"font-size: 1.1em;line-height: 3em\">\n          <h1 class=\"subheading font-weight-bold mb-2 indigo--text\">\n            Alexandre ZANNI\n          </h1>\n          <h2 class=\"subheading font-weight-regular mb-2\">\n            Portfolio - Développeur Web Vue.js\n          </h2>\n        </v-card-text>\n\n        <v-card flat tile class=\"mx-auto\" :width=\"largueurElementsDesktop\">\n        <v-card-text style=\"font-size: 1.3em;line-height: 1.7em\">\n          <p class=\"font-weight-regular\" align=\"justify\">\n            <b>Diplômé d'un DUT Informatique, je suis en recherche d’un emploi pour début juillet 2021</b>.\n            <br><br>\n            Dans le cadre d'un stage de fin d'études, j'ai été chargé du développement d'une application hybride\n            Android (tablette) et Desktop. Celle-ci est responsive, orientée utilisateur et elle est conçue à l'aide des\n            <b>frameworks Javascript Vue.js et de Web Design Vuetify</b>.\n            <br><br>\n            Ayant un profil orienté <b>front-end</b>, je peux réaliser des <b>maquettes ergonomiques</b> qui illustrent l'aspect\n            graphique et fonctionnel d'un site Web avec le logiciel <b>Figma</b>. Avec Vue.js, j'ai intégré des maquettes via\n            les composants Vuetify et le code Javascript associé, ainsi qu'une base de données via l'API IndexedDB.\n            <br><br>\n            Je serai réactif pour toute demande d’entretien, au téléphone ou au sein de vos locaux\n          </p>\n        </v-card-text>\n      </v-card>\n        </v-col>\n      </v-row>\n  </v-card>\n  </v-card>\n  </v-container>\n</template>\n\n<script>\nexport default {\n\n  data: () => ({\n    mobile: false,\n  }),\n\n  created () {\n    // Si le format est trop étroit (ex: mobile), basculer le mode d'affichage du menu latéral\n    if (this.$vuetify.breakpoint.mobile) {\n      this.mobile = true\n    } else {\n      this.mobile = false\n    }\n  },\n\n  computed: {\n    largueurElementsDesktop() {\n      if (this.mobile) {\n        return '100%'\n      }\n      else {\n        return '75%'\n      }\n    },\n  }\n};\n</script>\n"]}]}