{"remainingRequest":"C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\thread-loader\\dist\\cjs.js!C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\babel-loader\\lib\\index.js!C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\cache-loader\\dist\\cjs.js??ref--0-0!C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\src\\components\\Mobile.vue?vue&type=script&lang=js&","dependencies":[{"path":"C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\src\\components\\Mobile.vue","mtime":1625521628359},{"path":"C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\thread-loader\\dist\\cjs.js","mtime":499162500000},{"path":"C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\babel-loader\\lib\\index.js","mtime":315532800000},{"path":"C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"C:\\Users\\Utilisateur\\Desktop\\INFORMATIQUE\\PORTFOLIO\\node_modules\\vue-loader\\lib\\index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Mobile.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAyFA,eAAA;AAEA,EAAA,IAAA,EAAA,OAAA;AACA,IAAA,MAAA,EAAA;AADA,GAAA,CAFA;;AAMA,EAAA,OAAA,GAAA;AACA;AACA,QAAA,KAAA,QAAA,CAAA,UAAA,CAAA,MAAA,EAAA;AACA,WAAA,MAAA,GAAA,IAAA;AACA,KAFA,MAEA;AACA,WAAA,MAAA,GAAA,KAAA;AACA;AACA,GAbA;;AAeA,EAAA,QAAA,EAAA;AACA,IAAA,oBAAA,GAAA;AACA,UAAA,KAAA,MAAA,EAAA;AACA,eAAA,MAAA;AACA,OAFA,MAGA;AACA,eAAA,KAAA;AACA;AACA,KARA;;AAUA,IAAA,oBAAA,GAAA;AACA,UAAA,KAAA,MAAA,EAAA;AACA,eAAA,MAAA;AACA,OAFA,MAGA;AACA,eAAA,KAAA;AACA;AACA;;AAjBA;AAfA,CAAA","sourcesContent":["<template>\n  <v-container id='Mobile'>\n        <v-card class=\"mx-auto\">\n          <v-row align=\"center\" justify=\"center\" dense>\n            <v-spacer></v-spacer>\n              <v-card flat tile :width=\"largueurImageDesktop\" >\n                  <v-img src=\"../../public/images/pic05.jpg\" tile width=\"100%\"></v-img>\n              </v-card>\n              <v-spacer></v-spacer>\n              <v-spacer></v-spacer>\n              <v-card flat tile class=\"mx-auto\" :width=\"largueurTexteDesktop\" >\n                <br><br>\n                <v-card-title>\n                  <h2 class=\"subheading font-weight-bold mb-2\">Mobile&nbsp;</h2>\n                  <v-icon color=\"black\">mdi-android</v-icon>\n                </v-card-title>\n                <v-card color=\"blue lighten-5\">\n                <v-card-title>\n                  <h3 class=\"subheading font-weight-bold mb-2\">Projet de groupe nommé 'plantGO' (septembre 2020-avril 2021)</h3>\n                </v-card-title>\n                </v-card>\n                <v-row class=\"text-center\">\n                  <v-col class=\"mb-5\" cols=\"12\">\n                    <v-card flat tile class=\"mx-auto\">\n                      <v-card-text style=\"font-size: 1.3em;line-height: 1.7em\">\n                        <p class=\"font-weight-regular\" align=\"justify\">\n                          <b><i>Contexte</i></b> : Application mobile ludique Android qui vise à apporter des connaissances encyclopédiques par la collection de cartes de plantes,\n                          à la manière d’un “herbier virtuel”. Une carte Google Maps indique une zone de recherche localisant les plantes à photographier. Le joueur profite\n                          de pauses récréatives via l’obtention de cosmétiques afin de personnaliser son avatar ainsi que de deux mini-jeux de plateforme.\n                          <br><br>\n                            <b><i>Mon rôle</i></b> : Chef de projet.\n                          <br><br>\n                            <b><i>Mes tâches</i></b> :\n                            <ul>\n                              <li><i>Rédaction</i> : Organisation du plan des parties, écriture et relectures.\n                              </li>\n                              <li><i>Gestion</i> : Assignation des tâches, tenue des délais, gestion du projet via un Trello.</li>\n                              <li><i>Programmation</i> : Développement des mini-jeux et intégration des maquettes.</li>\n                            </ul>\n                          <br>\n                            <b><i>Rôle des autres membres du groupe</i></b> : Design UI / UX. Implémentation APIs.\n                          <br><br>\n                            <b><i>Technologies</i></b> :\n                            <ul>\n                              <li><i>Front-end Dev</i> : Android Studio (Java) avec le framework libGDX pour l'aspect jeu-vidéo.\n                              </li>\n                              <li><i>Front-end Design</i> : Design maquettes avec Figma. Level-Design des mini-jeux avec 'Tiled Map Editor' et import des sprites avec 'TexturePackerGUI'.</li>\n                              <li><i>APIs</i> : Identification espèces botaniques à partir de photographies (pl@ntNet). Extraction données encyclopédiques (Trefle). Carte avec géolocalisation GPS (Google Maps).</li>\n                            </ul>\n                          <br><br>\n                        </p>\n                      </v-card-text>\n                  </v-card>\n                    <v-row justify=\"center\">\n                      <v-spacer></v-spacer>\n                      <v-btn text tile href=\"https://github.com/zanniadevweb/plantGO_official\">\n                        <v-btn rounded small elevation=\"2\" fab color=\"indigo\">\n                          <v-icon color=\"white\">mdi-github</v-icon>\n                        </v-btn>\n                        <a>&nbsp;GitHub</a>\n                      </v-btn>\n                      <v-spacer></v-spacer>\n                      <v-btn text tile href=\"https://trello.com/b/Kp12eugz/projet-tutor%C3%A9-s2-plantgo\">\n                        <v-btn rounded small elevation=\"2\" fab color=\"indigo\">\n                          <v-icon color=\"white\">mdi-trello</v-icon>\n                        </v-btn>\n                        <a>&nbsp;Trello</a>\n                      </v-btn>\n                      <v-spacer></v-spacer>\n                      <v-btn text tile href=\"https://www.youtube.com/watch?v=JSq6NyNP-es\">\n                        <v-btn rounded small elevation=\"2\" fab color=\"indigo\">\n                          <v-icon color=\"white\">mdi-youtube</v-icon>\n                        </v-btn>\n                        <a>&nbsp;YouTube</a>\n                      </v-btn>\n                      <v-spacer></v-spacer>\n                    </v-row>\n                  </v-col>\n                </v-row>\n            <br><br>\n            </v-card>\n          <v-spacer></v-spacer>\n          <v-spacer></v-spacer>\n          </v-row>\n        </v-card>\n  </v-container>\n</template>\n\n<script>\nexport default {\n\n  data: () => ({\n    mobile: false,\n  }),\n\n  created () {\n    // Si le format est trop étroit (ex: mobile), basculer le mode d'affichage du menu latéral\n    if (this.$vuetify.breakpoint.mobile) {\n      this.mobile = true\n    } else {\n      this.mobile = false\n    }\n  },\n\n  computed: {\n    largueurImageDesktop() {\n      if (this.mobile) {\n        return '100%'\n      }\n      else {\n        return '25%'\n      }\n    },\n\n    largueurTexteDesktop() {\n      if (this.mobile) {\n        return '100%'\n      }\n      else {\n        return '60%'\n      }\n    },\n  }\n};\n</script>\n"],"sourceRoot":"src/components"}]}